#!/bin/sh

commit_msg_file="$1"
commit_msg=$(sed -n '1p' "$commit_msg_file")

case "$commit_msg" in
  Merge\ *|Revert\ *)
    exit 0
    ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|release|revert|style|test)(\([a-z0-9._/-]+\))?!?: .+$'

if printf '%s' "$commit_msg" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
Invalid commit message format.

Use one of the following formats:
  type: subject
  type(scope): subject

Allowed types:
  build, chore, ci, docs, feat, fix, perf, refactor, release, revert, style, test

Examples:
  feat(auth): add refresh token rotation
  fix: handle null query parameter in user listing
  docs(readme): update quick start commands
EOF

exit 1
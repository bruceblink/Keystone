# ─────────────────────────────────────────────────────────────────────────────
# Keystone Docker development environment template
# Copy this file to .env and update sensitive values before running compose.
# ─────────────────────────────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=12345
MYSQL_DATABASE=keystone
# Host exposed port (avoid conflict with local MySQL)
MYSQL_HOST_PORT=3306

# Redis
REDIS_PASSWORD=12345
# Host bind address (127.0.0.1 for local-only, 0.0.0.0 for LAN access)
REDIS_BIND_HOST=127.0.0.1
# Host exposed port
REDIS_HOST_PORT=6379
# Redis memory settings
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONTAINER_MEM_LIMIT=512m

# Spring Boot application
APP_HOST_PORT=18080
TOKEN_SECRET=changeme-please-update-in-production
DRUID_PASSWORD=keystone

# Optional datasource password decryption
KEYSTONE_DATASOURCE_PASSWORD_ENCRYPTION_ENABLED=false
KEYSTONE_DATASOURCE_ENCRYPT_KEY=

# Keylo auth (used in prod profile / docker compose)
# Defaults below allow local/prod container startup without external Keylo.
KEYSTONE_AUTH_MODE=local
KEYSTONE_AUTH_KEYLO_ENABLED=false
KEYLO_ISSUER_URI=http://keylo.local
KEYLO_JWK_SET_URI=http://keylo.local/.well-known/jwks.json
KEYLO_AUDIENCE=keystone
KEYLO_SUBJECT_CLAIM=sub
KEYLO_CREDENTIAL_VERIFY_URL=http://keylo.local/api/auth/verify
KEYLO_CREDENTIAL_AUTH_HEADER_NAME=Authorization
KEYLO_CREDENTIAL_AUTH_HEADER_VALUE=Bearer replace-with-keylo-token
KEYLO_CREDENTIAL_USERNAME_FIELD=username
KEYLO_CREDENTIAL_PASSWORD_FIELD=password
# Keylo provisioning (enable after local initialization is done)
KEYLO_PROVISIONING_ENABLED=false
KEYLO_CREATE_USER_URL=http://keylo.local/api/users
KEYLO_AUTH_HEADER_NAME=Authorization
KEYLO_AUTH_HEADER_VALUE=Bearer replace-with-keylo-admin-token
KEYLO_TIMEOUT_MILLIS=10000
KEYLO_SUBJECT_FIELD=subject
KEYLO_USERNAME_FIELD=username
KEYLO_NICKNAME_FIELD=nickname
KEYLO_EMAIL_FIELD=email
KEYLO_PHONE_FIELD=phoneNumber

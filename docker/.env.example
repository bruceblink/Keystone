# Keystone Docker environment template.
# Copy this file to .env and replace all production secrets before deployment.

# Infrastructure
MYSQL_ROOT_PASSWORD=12345
MYSQL_DATABASE=keystone
MYSQL_HOST_PORT=33066

REDIS_PASSWORD=12345
REDIS_BIND_HOST=127.0.0.1
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONTAINER_MEM_LIMIT=512m

# Keystone runtime
APP_HOST_PORT=18080
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/keystone?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=12345
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=12345
SPRING_DATA_REDIS_DATABASE=0
TOKEN_SECRET=replace-with-at-least-32-bytes-secret
DRUID_PASSWORD=replace-with-druid-password
SPRINGDOC_ENABLED=false
LOG_PATH=/app/logs
KEYSTONE_FILE_BASE_DIR=/app/data
KEYSTONE_FRONTEND_URL=http://localhost:80

# Optional datasource password decryption
KEYSTONE_DATASOURCE_PASSWORD_ENCRYPTION_ENABLED=false
KEYSTONE_DATASOURCE_ENCRYPT_KEY=

# Keylo auth
KEYSTONE_AUTH_MODE=mixed
KEYSTONE_AUTH_KEYLO_ENABLED=true
KEYLO_BASE_URL=http://10.17.17.7:2345
KEYLO_AUDIENCES=admin-backend
KEYLO_CREDENTIAL_AUTH_HEADER_VALUE=

# Keylo user provisioning
KEYLO_PROVISIONING_ENABLED=false
KEYLO_ADMIN_CLIENT_ID=cli-admin-root
KEYLO_ADMIN_CLIENT_SECRET=replace-with-strong-admin-secret
KEYLO_AUTH_HEADER_VALUE=

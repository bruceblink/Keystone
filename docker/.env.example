# ─────────────────────────────────────────────────────────────────────────────
# Keystone Docker development environment template
# Copy this file to .env and update sensitive values before running compose.
# ─────────────────────────────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=12345
MYSQL_DATABASE=keystone
# Host exposed port (avoid conflict with local MySQL)
MYSQL_HOST_PORT=3306

# Redis
REDIS_PASSWORD=12345
# Host exposed port
REDIS_HOST_PORT=6379
# Redis memory settings
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONTAINER_MEM_LIMIT=512m

# Spring Boot application
APP_HOST_PORT=18080
TOKEN_SECRET=changeme-please-update-in-production
DRUID_PASSWORD=keystone

# Optional datasource password decryption
KEYSTONE_DATASOURCE_PASSWORD_ENCRYPTION_ENABLED=false
KEYSTONE_DATASOURCE_ENCRYPT_KEY=

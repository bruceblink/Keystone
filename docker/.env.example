# Keystone Docker environment template.
# Copy this file to .env and replace all production secrets before deployment.

# Infrastructure
MYSQL_DATABASE=keystone
MYSQL_HOST_PORT=33066

REDIS_BIND_HOST=127.0.0.1
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONTAINER_MEM_LIMIT=512m

# Keystone runtime
APP_HOST_PORT=18080
SPRING_PROFILES_ACTIVE=prod
TOKEN_SECRET=replace-with-at-least-32-bytes-secret
KEYSTONE_RSA_PRIVATE_KEY=replace-with-base64-pkcs8-rsa-private-key
DRUID_USERNAME=keystone
DRUID_PASSWORD=replace-with-druid-password
KEYLO_ISSUER_URI=
KEYLO_TRUSTED_ISSUERS=
KEYLO_JWK_SET_URI=
KEYLO_CREDENTIAL_VERIFY_URL=
KEYLO_CREATE_USER_URL=
KEYLO_ADMIN_TOKEN_URL=

# Secret files
# Run from repository root:
#   python scripts/secret_tool.py generate-deployment --keep-database-plain
# If docker/.secrets/.database_password exists and is not empty, the script uses it.
# Otherwise it generates a strong random database password.
# This creates docker/.secrets/.database_password for first-time database initialization,
# plus AES-GCM encrypted runtime password files for Keystone.
# After the database has initialized successfully, delete docker/.secrets/.database_password.
KEYSTONE_DATASOURCE_PASSWORD_ENCRYPTION_ENABLED=true
KEYSTONE_REDIS_PASSWORD_ENCRYPTION_ENABLED=true
DATABASE_PASSWORD_FILE=./.secrets/.database_password

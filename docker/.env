# ─────────────────────────────────────────────────────────────────────────────
# AgileBoot Docker 开发环境配置
# 复制此文件为 .env.local 并修改敏感值（.env.local 已加入 .gitignore）
# ─────────────────────────────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=12345
MYSQL_DATABASE=agileboot
# 宿主机暴露端口（避免与本地 MySQL 冲突）
MYSQL_HOST_PORT=3306

# Redis
REDIS_PASSWORD=12345
# 宿主机暴露端口
REDIS_HOST_PORT=6379

# Spring Boot 应用
APP_HOST_PORT=8080
